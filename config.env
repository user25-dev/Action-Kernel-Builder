KERNEL_SOURCE=https://github.com/user25-dev/android_kernel_xiaomi_earth.git
KERNEL_SOURCE_BRANCH=lineage-23.2
KERNEL_DEFCONFIG=earth_defconfig
TARGET_ARCH=arm64
KERNEL_FILE=Image.gz-dtb
EXTRA_BUILD_COMMAND:CC=clang READELF=llvm-readelf OBJCOPY=llvm-objcopy AS=llvm-as LD=ld.lld NM=llvm-nm OBJDUMP=llvm-objdump STRIP=llvm-strip CROSS_COMPILE_ARM32=arm-linux-gnueabi-
NEED_DTBO=false
MAKE_BOOT_IMAGE=false
SOURCE_BOOT_IMAGE=https://mirrorbits.lineageos.org/full/earth/20260215/boot.img